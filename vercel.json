{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/telegram.js": {
      "maxDuration": 300
    },
    "api/worker.js": {
      "maxDuration": 300
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/lily",
      "dest": "/api/lily.js"
    },
    {
      "src": "/api/lily",
      "dest": "/api/lily.js"
    },
    {
      "src": "/api/wecom",
      "dest": "/api/wecom.js"
    },
    {
      "src": "/api/telegram",
      "dest": "/api/telegram.js"
    },
    {
      "src": "/api/worker",
      "dest": "/api/worker.js"
    }
  ]
}
