OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
PORT=3000
TAVILY_API_KEY=tvly-your-web-search-key

# SQLite locally. For Vercel + a separate worker, use Turso so both share state.
LILY_DB_PATH=./data/lily.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
LILY_WORKER_INTERVAL_MS=3000
LILY_STATUS_INTERVAL_MS=45000
LILY_TASK_STALE_AFTER_SECONDS=90
LILY_WORKER_SECRET=choose-a-long-random-worker-secret
LILY_AGENT_MAX_ITERATIONS=20
LILY_AGENT_TIMEOUT_MS=900000
LILY_DEBUG=false
LILY_REPORT_DIR=./outputs/reports

# Resend email settings.
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM=Lily Agent <onboarding@resend.dev>
EMAIL_SEND_SECRET=choose-a-long-random-secret

# Telegram bot webhook settings.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Gmail API (OAuth access token with gmail.compose and gmail.send scopes).
GMAIL_ACCESS_TOKEN=your-google-oauth-access-token

# Optional Google Sheets API. Normal tasks do not require these variables.
GOOGLE_ACCESS_TOKEN=your-google-oauth-access-token
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Wechaty worker settings. This worker runs outside Vercel.
LILY_API_URL=https://lily-agent-rouge.vercel.app/api/lily
WECHATY_NAME=lily-agent-wechat
WECHATY_PUPPET=wechaty-puppet-service
WECHATY_PUPPET_SERVICE_TOKEN=your-wechaty-puppet-service-token
WECHAT_ALLOWED_CONTACTS=John,Shuai
